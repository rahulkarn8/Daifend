{
  email {$ACME_EMAIL}
  # Keep logs concise; set to debug during troubleshooting.
}

{$DOMAIN} {
  encode zstd gzip

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    Referrer-Policy "strict-origin-when-cross-origin"
    Permissions-Policy "geolocation=(), microphone=(), camera=()"
    -Server
  }

  # Serve immutable Next static assets efficiently
  @nextStatic path /_next/static/*
  header @nextStatic Cache-Control "public, max-age=31536000, immutable"

  # Reverse proxy to Next.js container
  reverse_proxy app:3000 {
    header_up X-Forwarded-Proto {scheme}
    header_up X-Forwarded-For {remote_host}
    header_up X-Forwarded-Host {host}
  }
}

